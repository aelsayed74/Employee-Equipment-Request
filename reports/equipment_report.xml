<odoo>
    <record id="request_report" model="ir.actions.report">
        <field name="name"> request report</field>    
        <field name="model">employee.equipment.request</field>    
        <field name="report_type">qweb-pdf</field>    
        <field name="binding_model_id" ref="model_employee_equipment_request"/>    
        <field name="binding_type">report</field>    
        <field name="report_name">employee_equipment_request.request_report_template</field>      
    </record>

    <template id="request_report_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page" style="font-family: 'Helvetica', 'Arial', sans-serif;">
                        
                        <div class="row mt-4 mb-4 border-bottom pb-3">
                            <div class="col-12 text-center">
                                <h2 style="color: #1F4E79; font-weight: bold;">Equipment Request Details</h2>
                                <h4 class="text-muted"><t t-out="o.ref"/></h4>
                            </div>
                        </div>

                        <div class="row mb-4">
                            <div class="col-6">
                                <strong>Employee Name:</strong> <t t-out="o.employee_id.name or o.employee_name"/><br/>
                                <strong>Equipment Type:</strong> <span class="badge bg-secondary" style="font-size: 14px;"><t t-out="o.equipment_type"/></span><br/>
                            </div>
                            <div class="col-6 text-end">
                                <strong>Request Date:</strong> <t t-out="o.created_at" t-options='{"widget": "date"}'/><br/>
                                <strong>Status:</strong> 
                                <span t-attf-class="badge #{'bg-warning' if o.state == 'submitted' else 'bg-success' if o.state == 'approved' else 'bg-danger' if o.state == 'rejected' else 'bg-info'}" style="font-size: 14px;">
                                    <t t-out="o.state.capitalize()"/>
                                </span>
                            </div>
                        </div>

                        <div class="card mb-4">
                            <div class="card-header" style="background-color: #F2F4F7; color: #1F4E79; font-weight: bold;">
                                Request Description
                            </div>
                            <div class="card-body">
                                <p class="card-text">
                                    <t t-if="o.description" t-out="o.description"/>
                                    <t t-else="">No description provided.</t>
                                </p>
                            </div>
                        </div>

                        <t t-if="o.state == 'rejected' and o.rejection_reason">
                            <div class="card mb-4 border-danger">
                                <div class="card-header bg-danger text-white font-weight-bold">
                                    Rejection Reason
                                </div>
                                <div class="card-body text-danger">
                                    <p class="card-text"><t t-out="o.rejection_reason"/></p>
                                </div>
                            </div>
                        </t>

                        <div class="row mt-5 pt-5">
                            <div class="col-4 text-center">
                                <p class="border-top pt-2"><strong>Employee Signature</strong></p>
                                <br/><br/>
                                <span>______________________</span>
                            </div>
                            <div class="col-4"></div>
                            <div class="col-4 text-center">
                                <p class="border-top pt-2"><strong>Manager Approval</strong></p>
                                <br/><br/>
                                <span>______________________</span>
                            </div>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>