<odoo>
    <record id="employee_equipment_category" model="ir.module.category">
        <field name="name">Employee Equipment</field>
    </record>
    <record id="employee_equipment_manager_group" model="res.groups">
        <field name="name">Employee Equipment Manager</field>
        <field name="category_id" ref="employee_equipment_request.employee_equipment_category"/>
    </record>
    <record id="employee_equipment_user_group" model="res.groups">
        <field name="name">Employee Equipment User</field>
        <field name="category_id" ref="employee_equipment_request.employee_equipment_category"/>
    </record>

    <!-- record rule -->
    <record id="employee_equipment_record_rule_by_user" model="ir.rule">
            <field name="name">employee.request.by.user</field>
            <field name="model_id" ref="model_employee_equipment_request"/>
            <field name="domain_force">['|', ('create_uid', '=', user.id), ('create_uid', '=', False)]</field>
            <field name="groups" eval="[(4, ref('employee_equipment_user_group'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="employee_equipment_record_rule_by_manager" model="ir.rule">
            <field name="name">employee.request.by.manager</field>
            <field name="model_id" ref="model_employee_equipment_request"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('employee_equipment_manager_group'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>  

</odoo>