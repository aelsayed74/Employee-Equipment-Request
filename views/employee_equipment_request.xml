<odoo>
    <record id="employee_equipment_request_view_tree" model="ir.ui.view">
    <field name="name">employee equipment request tree</field>
    <field name="model">employee.equipment.request</field>
    <field name="arch" type="xml">
        <tree class="header_custom" decoration-danger="is_late" sample="1"> 
            
            <field name="is_late" column_invisible="True"/>
            
            <field name="ref" string="Reference" class="text-black font-weight-bold"/>
            <field name="employee_name" string="Name" class="text-center text-black"/>
            <field name="equipment_type" string="Equipment Type" class="text-center text-black"/>
            <field name="created_at" string="Created At" class="text-center text-black"/>
            
            <field name="state" string="Status" widget="badge" 
                   decoration-info="state == 'draft'" 
                   decoration-warning="state == 'submitted'" 
                   decoration-success="state in ('approved', 'done')" 
                   decoration-danger="state == 'rejected'"/>
        </tree>
    </field>
    </record>

    <record id="employee_equipment_request_view_kanban" model="ir.ui.view">
    <field name="name">employee.equipment.request.kanban</field>
    <field name="model">employee.equipment.request</field>
    <field name="arch" type="xml">
        <kanban default_group_by="state" class="o_kanban_small_column">
            <field name="is_late"/> 
            <field name="employee_name"/>
            <field name="equipment_type"/>
            
            <templates>
                <t t-name="kanban-box">
                    <div t-attf-class="oe_kanban_card oe_kanban_global_click #{record.is_late.raw_value ? 'border-danger bg-danger-light text-danger' : ''}">
                        <div class="oe_kanban_content">
                            <div class="o_kanban_record_title font-weight-bold">
                                <strong><field name="employee_name"/></strong>
                            </div>
                            <div>
                                <span class="text-muted">Device: </span>
                                <field name="equipment_type"/>
                            </div>
                            <t t-if="record.is_late.raw_value">
                                <div class="badge rounded-pill bg-danger text-white mt-2">Very late request</div>
                            </t>
                        </div>
                    </div>
                </t>
            </templates>
        </kanban>
    </field>
    </record>


    <record id="employee_equipment_request_view_form" model="ir.ui.view">
    <field name="name">employee equipment request form</field>
    <field name="model">employee.equipment.request</field>
    <field name="arch" type="xml">
        <form>
            <header>
                <button name="action_draft" type="object" class="btn-primary" string="Draft"
                        invisible="state in ('draft',)"/>
                <button name="action_submitted" type="object" class="btn-secondary" string="Submitted"
                        invisible="state in ('done','rejected','submitted')"/>
                <button name="action_approved" type="object" class="btn-success" string="Approved"
                        invisible="state in ('done','rejected','approved')"/>
                <button name="action_rejected" type="object" class="btn-danger" string="Rejected"
                        invisible="state in ('approved','done','rejected')"/>
                <button name="action_done" type="object" class="btn-success" string="Done"
                        invisible="state != 'approved'"/>
                <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved,done"/>
            </header>
            
            <sheet>
                <widget name="web_ribbon" title="LATE" bg_color="text-bg-danger" invisible="not is_late"/>
                
                <div class="oe_title">
                    <label for="ref"/>
                    <h1>
                        <field name="ref" readonly="1"/>
                    </h1>
                </div>
                
                <group>
                    <group>
                        <field name="employee_name" string="Name"/>
                        <field name="equipment_type" string="Equipment Type"/>
                        <field name="created_at" string="Created At"/>
                    </group>
                    <group>
                        <field name="description" string="Description"/>
                        <field name="rejection_reason" string="Rejection Reason" invisible="state != 'rejected'" required="state == 'rejected'"/>
                        <field name="is_late" invisible="1"/>
                    </group>
                </group>
            </sheet>
            
            <div class="oe_chatter">
                <field name="message_follower_ids"/>
                <field name="activity_ids"/>
                <field name="message_ids"/>
            </div>
        </form> 
    </field>
    </record>
    <record id="employee_equipment_request_action" model="ir.actions.act_window">
        <field name="name">Equipment Request</field>
        <field name="res_model">employee.equipment.request</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="context">{'search_default_group_by_state': 1}</field>
    </record>

    <record id="employee_equipment_request_view_search" model="ir.ui.view">
        <field name="name">employee equipment request search</field>
        <field name="model">employee.equipment.request</field>
        <field name="arch" type="xml">
            <search>
                <field name="ref"/>
                <field name="employee_name"/>
                <filter name="is_submitted" string="Is Submitted" domain="[('state','=','submitted')]"/>
                <filter name="group_equipment" string="Group Equipment" context="{'group_by':'equipment_type'}"/>
            </search> 
        </field>
    </record>

     <record id="check_submit_state_cron" model="ir.cron">
            <field name="name">Employee Equipment Request: Check Late Submitted Requests</field>
            <field name="model_id" ref="model_employee_equipment_request"/>
            <field name="state">code</field>
            <field name="code">model.action_send_pending_requests_reminder()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field> 
            <field name="numbercall">-1</field> 
            <field name="active">True</field>
    </record>

    <menuitem
        id="equipment_request_menu_item"
        name="employee"
        parent="employee_request_root_menu"
        action="employee_equipment_request_action"
        groups="employee_equipment_request.employee_equipment_manager_group,employee_equipment_request.employee_equipment_user_group"
    />
</odoo>