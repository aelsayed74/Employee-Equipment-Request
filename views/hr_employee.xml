<odoo>
    <record id="view_employee_form_inherit_equipment_button" model="ir.ui.view">
        <field name="name">hr.employee.form.inherit.equipment.button</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_equipment_requests"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-laptop">
                    <field name="equipment_request_count" widget="statinfo" string="Equipments"/>
                </button>
            </xpath>

        </field>
    </record>
</odoo>